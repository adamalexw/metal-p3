generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Album {
  AlbumId             Int             @id @default(autoincrement())
  BandId              Int?
  Folder              String
  Name                String?
  Year                Int?
  MetalArchiveUrl     String?
  IgnoreMetalArchives Boolean?
  Lyrics              Boolean?
  LyricsDate          DateTime?
  Transferred         Boolean?
  TransferredDate     DateTime?
  Created             DateTime        @default(now())
  Played              Boolean?
  Band                Band?           @relation(fields: [BandId], references: [BandId], onDelete: Cascade)
  LyricsError         LyricsError[]
  LyricsHistory       LyricsHistory[]
}

model Band {
  BandId          Int             @id @default(autoincrement())
  Name            String
  Genre           String?
  Country         String?
  MetalArchiveUrl String?
  Created         DateTime        @default(now())
  Album           Album[]
  NewAlbum        NewAlbum[]
  NewAlbumError   NewAlbumError[]
}

model LyricsError {
  LyricsErrorId Int     @id @default(autoincrement())
  AlbumId       Int
  Url           String?
  Error         String?
  Album         Album   @relation(fields: [AlbumId], references: [AlbumId], onDelete: Cascade)
}

model LyricsHistory {
  LyricsHistoryId  Int      @id @default(autoincrement())
  AlbumId          Int
  NumTracks        Int?
  NumLyrics        Int?
  NumLyricsHistory Int?
  Checked          Boolean?
  Priority         Boolean?
  Album            Album    @relation(fields: [AlbumId], references: [AlbumId], onDelete: Cascade)
}

model NewAlbum {
  NewAlbumId      Int     @id @default(autoincrement())
  BandId          Int
  Album           String?
  Year            Int?
  MetalArchiveUrl String?
  Band            Band    @relation(fields: [BandId], references: [BandId], onDelete: Cascade)
}

model NewAlbumError {
  NewAlbumErrorId Int     @id @default(autoincrement())
  BandId          Int
  Error           String?
  Band            Band    @relation(fields: [BandId], references: [BandId], onDelete: Cascade)
}

model Playlist {
  PlaylistId   Int            @id @default(autoincrement())
  PlaylistName String
  PlaylistItem PlaylistItem[]
}

model PlaylistItem {
  PlaylistItemId Int      @id @default(autoincrement())
  PlaylistId     Int
  ItemPath       String
  ItemIndex      Int
  Playlist       Playlist @relation(fields: [PlaylistId], references: [PlaylistId], onDelete: Cascade)
}
