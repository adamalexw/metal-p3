{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "start": {
      "dependsOn": ["sync-deps"],
      "options": {
        "args": ["--port=8081"]
      }
    },
    "serve": {
      "dependsOn": ["sync-deps"],
      "options": {
        "args": ["--port=4200"]
      }
    },
    "run-ios": {
      "dependsOn": ["sync-deps"],
      "options": {
        "args": []
      }
    },
    "run-android": {
      "dependsOn": ["sync-deps"],
      "options": {
        "args": []
      }
    },
    "build": {
      "dependsOn": ["sync-deps"]
    },
    "build-list": {
      "executor": "@nx/expo:build-list",
      "options": {}
    },
    "sync-deps": {
      "executor": "@nx/expo:sync-deps",
      "options": {}
    },
    "prebuild": {
      "dependsOn": ["sync-deps"]
    },
    "update": {
      "executor": "@nx/expo:update",
      "options": {}
    },
    "export": {
      "dependsOn": ["sync-deps"],
      "outputs": ["{projectRoot}/{options.outputDir}", "{workspaceRoot}/apps/mobile/dist"],
      "options": {
        "args": ["--output-dir=../../apps/mobile/dist", "--platform=all"]
      }
    }
  }
}
