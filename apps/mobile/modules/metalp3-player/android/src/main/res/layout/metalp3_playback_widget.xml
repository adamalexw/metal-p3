<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/metalp3_widget_background"
    android:padding="10dp"
    android:gravity="center_vertical">

  <ImageView
      android:id="@+id/metalp3_widget_art"
      android:layout_width="90dp"
      android:layout_height="90dp"
      android:scaleType="centerCrop"
      android:adjustViewBounds="true"
      android:background="@drawable/metalp3_widget_art_placeholder"
      android:src="@drawable/metalp3_widget_ic_note"
      android:contentDescription="@string/metalp3_widget_label" />

  <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="12dp"
      android:layout_marginEnd="8dp"
      android:orientation="vertical">

    <TextView
        android:id="@+id/metalp3_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="@string/metalp3_widget_idle" />

    <TextView
        android:id="@+id/metalp3_widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A0A0A0"
        android:textSize="12sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginTop="2dp"
        android:text="@string/metalp3_widget_tap_to_open" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

      <ImageButton
          android:id="@+id/metalp3_widget_prev"
          android:layout_width="44dp"
          android:layout_height="44dp"
          android:background="?android:attr/selectableItemBackgroundBorderless"
          android:src="@drawable/metalp3_widget_ic_prev"
          android:scaleType="center"
          android:contentDescription="Previous" />

      <ImageButton
          android:id="@+id/metalp3_widget_play_pause"
          android:layout_width="48dp"
          android:layout_height="48dp"
          android:layout_marginStart="6dp"
          android:layout_marginEnd="6dp"
          android:background="?android:attr/selectableItemBackgroundBorderless"
          android:src="@drawable/metalp3_widget_ic_play"
          android:scaleType="center"
          android:contentDescription="Play/Pause" />

      <ImageButton
          android:id="@+id/metalp3_widget_next"
          android:layout_width="44dp"
          android:layout_height="44dp"
          android:background="?android:attr/selectableItemBackgroundBorderless"
          android:src="@drawable/metalp3_widget_ic_next"
          android:scaleType="center"
          android:contentDescription="Next" />
    </LinearLayout>
  </LinearLayout>
</LinearLayout>
